{
  "name": "kafka-sse",
  "version": "0.4.3",
  "description": "KafkaSSE - Kafka Consumer to HTTP SSE/EventSource",
  "main": "index.js",
  "scripts": {
    "start": "./server.js | ./node_modules/bunyan/bin/bunyan",
    "test": "jest --verbose --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "redpanda-fixture": "./test/utils/redpanda_fixture.sh",
    "test-docker": "./test/docker-tests.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wikimedia/KafkaSSE.git"
  },
  "keywords": [
    "kafka",
    "http",
    "sse",
    "eventsource",
    "stream"
  ],
  "author": "Andrew Otto <otto@wikimedia.org>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wikimedia/KafkaSSE/issues"
  },
  "homepage": "https://github.com/wikimedia/KafkaSSE#readme",
  "dependencies": {
    "bluebird": "^3.5.1",
    "bunyan": "^1.8.1",
    "kafkajs": "^2.2.4",
    "lodash": "^4.15.0",
    "safe-regex": "^1.1.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^3.3.2",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "eventsource": "^0.2.1",
    "jest": "^29.7.0",
    "node-fetch": "^1.6.3",
    "sinon": "^17.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"],
    "collectCoverageFrom": ["lib/**/*.js"],
    "coverageDirectory": "coverage",
    "forceExit": true
  }
}
